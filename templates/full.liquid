<div class="layout layout--col gap--distribute">
  <!-- Current Conditions + 6-Day -->
  <div class="flex flex--between flex--center-y w--full pb--1 border-b-2">
    <div class="flex flex--center-y gap--small no-shrink">
      <i class="wi {{ current.icon }} {% if current.is_precip %}wi-precip{% endif %} wi-xxl"></i>
      <span class="value value--xxlarge bold">{{ current.temp }}°</span>
      <div>
        <span class="label label--small bold">{{ current.condition }}</span>
        <div class="description text-sm">{{ current.wind_dir }} {{ current.wind_speed }}km/h · {{ current.humidity }}%</div>
      </div>
    </div>

    <!-- 6-Day Forecast -->
    <table class="daily-tbl">
      <tr>
        {% for day in daily limit: 6 %}
          <td><span class="label label--small bold">{{ day.day }}</span></td>
        {% endfor %}
      </tr>
      <tr>
        {% for day in daily limit: 6 %}
          <td><i class="wi {{ day.icon }} {% if day.is_precip %}wi-precip{% endif %} wi-sm"></i></td>
        {% endfor %}
      </tr>
      <tr>
        {% for day in daily limit: 6 %}
          <td><span class="label label--small bold">{{ day.high }}°</span></td>
        {% endfor %}
      </tr>
      <tr>
        {% for day in daily limit: 6 %}
          <td><span class="description">{% if day.low %}{{ day.low }}°{% endif %}</span></td>
        {% endfor %}
      </tr>
    </table>
  </div>

  <!-- 24-Hour Forecast (3 cols x 8 rows) -->
  <table class="hourly-tbl grow">
    {% for row in (0..7) %}
      <tr>
        {% for col in (0..2) %}
          {% assign idx = col | times: 8 | plus: row %}
          {% assign h = hourly[idx] %}
          {% if h %}
            {% assign utc_epoch = h.time_iso | date: "%s" | plus: 0 %}
            {% assign local_epoch = utc_epoch | plus: trmnl.user.utc_offset %}
            <td class="nowrap text--right td-time"><span class="label">{{ local_epoch | date: "%-I%P" }}</span></td>
            <td class="td-icon text--center">
              <i class="wi {{ h.icon }} {% if h.is_precip %}wi-precip{% endif %} wi-md"></i>
            </td>
            <td class="nowrap text--right td-temp"><span class="label bold">{{ h.temp }}°</span></td>
            <td>
              <div class="hour-bar-wrap">
                {% if h.precip_bar > 0 %}
                  <div class="hour-bar" style="width: {{ h.precip_bar }}%;"></div>
                {% endif %}
              </div>
            </td>
            <td class="nowrap text--right" style="width: 28px;">
              {% if h.precip_mm > 0 %}<span class="description">{{ h.precip_mm }}mm</span>{% endif %}
            </td>
          {% endif %}
        {% endfor %}
      </tr>
    {% endfor %}
  </table>
</div>

<div class="title_bar">
  <span class="title">Yr.no Weather</span>
  <span class="instance">{{ lat }}, {{ lon }}</span>
</div>
