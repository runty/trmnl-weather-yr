<div class="layout layout--row gap--medium flex--center-y">
  <div class="no-shrink">
    <div class="flex flex--center-y gap--small">
      <i class="wi {{ current.icon }} {% if current.is_precip %}wi-precip{% endif %} wi-xl"></i>
      <span class="value value--xlarge bold">{{ current.temp }}°</span>
    </div>
    <div class="label label--small">{{ current.condition }}</div>
    <div class="description text-sm">{{ current.wind_dir }} {{ current.wind_speed }}km/h · {{ current.humidity }}%</div>
  </div>

  <div class="stretch-x pl--3 border-l-2">
    <table class="daily-tbl">
      <tr>{% for day in daily limit: 7 %}<td><span class="label label--small bold">{{ day.day }}</span></td>{% endfor %}</tr>
      <tr>{% for day in daily limit: 7 %}<td><i class="wi {{ day.icon }} {% if day.is_precip %}wi-precip{% endif %} wi-sm"></i></td>{% endfor %}</tr>
      <tr>{% for day in daily limit: 7 %}<td><span class="label label--small bold">{{ day.high }}°</span></td>{% endfor %}</tr>
    </table>
  </div>
</div>

<div class="title_bar">
  <span class="title">Yr.no Weather</span>
  <span class="instance">{{ lat }}, {{ lon }}</span>
</div>
